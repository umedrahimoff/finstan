# Telegram auth (username бота без @, ID глобального админа — числовой)
VITE_TELEGRAM_BOT_NAME=
VITE_TELEGRAM_GLOBAL_ADMIN_ID=

# Server (Vercel Environment Variables)
DATABASE_URL=postgresql://...  # Neon connection string
JWT_SECRET=                    # Секрет для JWT (минимум 32 символа)
TELEGRAM_BOT_TOKEN=            # Токен от @BotFather
TELEGRAM_GLOBAL_ADMIN_ID=      # Числовой Telegram ID админа
SITE_URL=                      # https://finstan.vercel.app (для ссылок в боте)

# После деплоя: установить webhook бота:
# curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://finstan.vercel.app/api/telegram-webhook"
